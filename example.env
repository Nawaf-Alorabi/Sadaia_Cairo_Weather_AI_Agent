# Location
LOCATION_NAME=Cairo, Egypt
LATITUDE=30.0444
LONGITUDE=31.2357

# AI message generation - optional.
# Leave empty and the app will use a simple fallback message.
OPENROUTER_API_KEY=
OPENROUTER_MODELS=openrouter/free

# Email
ENABLE_EMAIL=true
SENDER_EMAIL=
EMAIL_APP_PASSWORD=
RECEIVER_EMAIL=
EMAIL_SUBJECT=Cairo Weather Update

# Telegram - free and easy.
ENABLE_TELEGRAM=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
